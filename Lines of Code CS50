import sys

counter = 0

if len(sys.argv) < 2:
    print("Too few command-line arguments")
    sys.exit()
elif len(sys.argv) > 2:
    print("Too many command-line arguments")
if not sys.argv[1].endswith(".py"):
    print("Not a Python file")
    sys.exit()
try:
    with open(sys.argv[1], "r") as pyfile:
        for line in pyfile:
            if line.startswith("#"):
                counter = counter + 0
            elif line.strip() == "":
                counter = counter + 0
            else:
                counter = counter + 1
        print(counter)
except FileNotFoundError:
    print("File does not exist")
    sys.exit()
