from numb3rs.py import validate

def test_letters():
    assert validate("yowie") == False
    assert validate("a.b.c.d") == False
    assert validate("a.b.c.D.e.f.g") == False
    assert validate("1.2.4.?") == False
def test_normal():
    assert validate("1.2.3.4") == True
    assert validate("0.0.0.0") == True
    assert validate("255.255.255.255") == True
def test_abnormal():
    assert validate("2000.2000.200.200") == False
    assert validate("-1.-1.-1.-1") == False
